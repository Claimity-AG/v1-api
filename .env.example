# Claimity Partner API - example environment

# Required
#
# Pick one of the following CLIENT_ID / PRIVATE_KEY_PATH pairs depending on your role.
#
# Expert example:
CLIENT_ID=org-expo-00001
PRIVATE_KEY_PATH=./private-key.pem
#
# Insurer example:
# CLIENT_ID=org-inso-00003
# PRIVATE_KEY_PATH=./private-key-ins.pem
TOKEN_URL=https://app.claimity.ch/v1/oauth/token
TOKEN_AUDIENCE=https://app.claimity.ch/realms/claimity/protocol/openid-connect/token
API_BASE_URL=https://app.claimity.ch

# Optional
SCOPE=roles
KID=

# Optional: provide IDs to skip discovery
# Expert notebook:
CASE_ID=
SUBMISSION_ID=
DOC_ID=
# Insurer notebook:
CLAIM_ID=
REPORT_ID=

# Optional debugging (do NOT enable in production screenshots/logs)
DEBUG_PRINT_TOKEN_RESPONSE=false
DEBUG_PRINT_JWT_CLAIMS=false

